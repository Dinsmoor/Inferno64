TARGMODEL=	Posix
TARGSHTYPE=	sh
CPUS=		arm

# Plan 9 object letter (5 = arm): cross-built objects coexist with the
# build host's *.o in the same source dirs (tests/cunit/cross.sh builds
# the portable C libs with this file as the ILP32 little-endian canary)
O=		5
OS=		5

AR=		arm-linux-gnueabihf-ar
ARFLAGS=	ruvs

AS=		arm-linux-gnueabihf-gcc -c
ASFLAGS=

CC=		arm-linux-gnueabihf-gcc -c
CFLAGS=		-g -O\
		-Wuninitialized -Wunused-variable -Wreturn-type -Wimplicit\
		-I$ROOT/Linux/arm/include\
		-I$ROOT/include\
		-DLINUX_ARM

ANSICPP=
LD=		arm-linux-gnueabihf-gcc
LDFLAGS=

SYSLIBS=

YACC=		iyacc
YFLAGS=		-d
