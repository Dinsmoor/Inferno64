BINTARG=${TARG:%=$DISBIN/%}
MODDIR=$ROOT/module
SYS_MODULE=${SYSMODULES:%=$MODDIR/%}
LIMBOFLAGS=-I$MODDIR

all:V:		$TARG

install:V:	$BINTARG

installall:V:	install

clean:V: 	clean-std

nuke:V:		nuke-std

$DISBIN/%.dis:	%.dis
	mkdir -p $DISBIN && rm -f $DISBIN/$stem.dis && cp $stem.dis $DISBIN/$stem.dis

%.dis:		$MODULES $SYS_MODULE

# Rebuild a .dis when the limbo compiler itself changes, even if the .b is
# unchanged: mk only checks prerequisite mtimes, and the compiler binary was not
# a prerequisite, so a recompiled limbo did not invalidate stale .dis (a
# recurring "the fix didn't take" trap during the LP64 port).
LIMBOCMD=$ROOT/$OBJDIR/bin/limbo

%.dis:		$LIMBOCMD

%.dis:		%.b
	limbo $LIMBOFLAGS -gw $stem.b

%.s:		%.b
	limbo $LIMBOFLAGS -w -G -S $stem.b

%.install:V:	$DISBIN/%.dis
%.installall:V:	$DISBIN/%.dis

clean-std:V:
	rm -f *.dis *.sbl

# Remove the installed targets.  Iterate rather than `rm -f $BINTARG` directly:
# when TARG is empty (e.g. a dir that ships only SHTARG scripts), the mk
# substitution ${TARG:%=$DISBIN/%} degenerates to a bare "$DISBIN/", and
# `rm -f` on that directory aborts the whole nuke pass ("Is a directory").
# Skipping directory entries keeps nuke robust for every leaf.
nuke-std:V:	clean-std
	for f in $BINTARG; do test -d "$f" || rm -f "$f"; done
