# Paths are relative to this mkfile's dir (libmbedtls/); the vendored upstream
# tree is libmbedtls/mbedtls/, so from here that is just mbedtls/.
%.$O: mbedtls/library/%.c
	$CC $CFLAGS -o $target $prereq

<$ROOT/mkfiles/mksyslib-$SHELLTYPE

# mbedTLS needs only its own include dir; keep the rest of $CFLAGS (arch
# flags) but add the vendored headers.
CFLAGS= $CFLAGS -Imbedtls/include
