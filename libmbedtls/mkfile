<../mkconfig

# Vendored mbedTLS 3.6.2 (Apache-2.0), built as one static lib for emu.
# Upstream sources live under libmbedtls/mbedtls/{include,library}; this
# mkfile compiles every library/*.c with the Inferno CC, mirroring the
# libfreetype vendoring pattern. They are plain ISO C and must NOT pull in
# Inferno's lib9.h (they only include libc + their own headers).

LIB=libmbedtls.a

OFILES=\
	aes.$O\
	aesce.$O\
	aesni.$O\
	aria.$O\
	asn1parse.$O\
	asn1write.$O\
	base64.$O\
	bignum.$O\
