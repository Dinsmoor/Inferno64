	chacha20.$O\
	chachapoly.$O\
	cipher.$O\
	cipher_wrap.$O\
	cmac.$O\
	constant_time.$O\
	ctr_drbg.$O\
	debug.$O\
	des.$O\
	dhm.$O\
	ecdh.$O\
