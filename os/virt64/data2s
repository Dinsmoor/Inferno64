#!/bin/sh
# data2s name < binary > asm   (GNU as flavor, for the gcc-built native kernel)
# Emits ${name}code (bytes) and ${name}len (int), matching what mkroot's
# generated C externs expect.
name="$1"
tmp="${TMPDIR:-/tmp}/data2s.$$"
trap 'rm -f "$tmp"' 0
cat > "$tmp"
size=$(wc -c < "$tmp" | tr -d ' ')
printf '\t.section .rodata\n'
printf '\t.balign 8\n'
printf '\t.globl %scode\n' "$name"
printf '%scode:\n' "$name"
od -An -v -tx1 "$tmp" | awk '{
	line = "\t.byte "
	for(i = 1; i <= NF; i++){
		if(i > 1) line = line ", "
		line = line "0x" $i
	}
	if(NF > 0) print line
}'
printf '\t.balign 4\n'
printf '\t.globl %slen\n' "$name"
printf '%slen:\t.int %s\n' "$name" "$size"
